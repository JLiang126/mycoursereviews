# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mycoursereviews"

# Redis Cache connection string
REDIS_URL="redis://localhost:6379"

# NextAuth core configuration
# You can generate a random secret key using: openssl rand -base64 32
AUTH_SECRET="your-super-secret-auth-key-goes-here"

# Keycloak config
KEYCLOAK_CLIENT_ID="mycoursereviews"
KEYCLOAK_CLIENT_SECRET="your-keycloak-client-secret"
KEYCLOAK_ISSUER="https://auth.csclub.org.au/realms/cs-club"

# Courses API endpoint
COURSES_API_URL="https://courses-api.csclub.org.au"

# Umami Analytics (optional)
NEXT_PUBLIC_UMAMI_WEBSITE_ID="your-umami-website-id"
