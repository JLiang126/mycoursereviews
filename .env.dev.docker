# PostgreSQL connection string 
DATABASE_URL="postgresql://postgres:postgres@mycoursereviews-db-dev:5432/mycoursereviews"

# Redis Cache connection string
REDIS_URL="redis://redis:6379"

# NextAuth core configuration
# You can generate a random secret key using: openssl rand -base64 32
AUTH_SECRET="your-docker-dev-secret-key-goes-here-32chars"

# Keycloak config
KEYCLOAK_CLIENT_ID="mycoursereviews"
KEYCLOAK_CLIENT_SECRET="**********"
KEYCLOAK_ISSUER="http://keycloak:8080/realms/cs-club"

NEXT_PUBLIC_CONTAINER_KEYCLOAK_ENDPOINT="http://keycloak:8080"
NEXT_PUBLIC_LOCAL_KEYCLOAK_URL="http://localhost:8080"

# Courses API endpoint
COURSES_API_URL="https://courses-api.csclub.org.au"
